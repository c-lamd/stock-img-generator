# Set the API key for your preferred provider.
# You only need ONE of these.

# OpenAI (GPT Image 1.5) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# fal.ai (Flux 2 Pro) — https://fal.ai/dashboard/keys
FAL_KEY=

# Stability AI (SD 3.5) — https://platform.stability.ai/account/keys
STABILITY_API_KEY=

# Optional: skip the provider selection prompt by setting a default.
# Options: OpenAI GPT Image, fal.ai Flux 2 Pro, Stability AI SD 3.5
# IMAGE_PROVIDER=OpenAI GPT Image
